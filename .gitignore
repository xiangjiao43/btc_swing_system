# ============= ENV FILES (CRITICAL: never commit) =============
# 历史教训:Sprint 2.6-A.4 的 .env.save 因 *.env 不匹配 .env.save 而被 commit。
# 从 incident 2026-04-27 起,扩展为 .env / .env.* / *.env / *.env.* 全覆盖,
# 加上常见编辑器备份后缀。
.env
.env.*
*.env
*.env.*
# 编辑器 / 工具备份(防误提交带凭据的备份文件)
*.bak
*.backup
*.save
*.swp
*.swo
*~
# ============= 其他敏感 =============
secrets/
credentials/
*.key
*.pem
*.p12
*.pfx
.htpasswd
*.htpasswd
config/local.*
config/prod.*
config/*.secret.*

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python
build/
dist/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# ---- uv / virtualenv ----
.venv/
venv/
env/
ENV/

# ---- Project data (runtime-generated, not source) ----
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/*.db.bak*

# ---- Runtime logs (scripts/test_*.py via tee) ----
logs_*.txt
*.log
data/logs/
data/reviews/

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Editors ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Jupyter ----
.ipynb_checkpoints/
