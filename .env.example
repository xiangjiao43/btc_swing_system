# ============================================================
# BTC Swing System - Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real keys.
#
# Reference: docs/modeling.md §10.2
# ============================================================

# ---- Binance (spot + derivatives) via proxy ----
BINANCE_BASE_URL=https://your-binance-proxy.com
BINANCE_API_KEY=optional_key_if_required

# ---- Glassnode (on-chain) via proxy ----
GLASSNODE_BASE_URL=https://your-glassnode-proxy.com
GLASSNODE_API_KEY=your_glassnode_key

# ---- Coinglass (derivatives aggregator) via proxy ----
COINGLASS_BASE_URL=https://your-coinglass-proxy.com
COINGLASS_API_KEY=your_coinglass_key

# ---- AI (Anthropic Claude) via proxy ----
AI_BASE_URL=https://your-ai-proxy.com
AI_API_KEY=your_ai_key
AI_MODEL_NAME=claude-opus-4-7

# ---- Application ----
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# SQLite file path (relative to project root)
DATABASE_URL=sqlite:///data/btc_strategy.db

# FastAPI server (v0.4+)
API_HOST=127.0.0.1
API_PORT=8000
