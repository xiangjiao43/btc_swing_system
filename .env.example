# ============================================================
# BTC Swing System — Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real keys.
#
# Reference:
#   - config/data_sources.yaml  (data sources, takes `..._BASE_URL` / `..._API_KEY`)
#   - config/ai.yaml            (AI endpoint + model)
# All variables below are OPTIONAL if the corresponding config has a
# usable `*_default`; they only need to be set to OVERRIDE the default.
# ============================================================


# ============================================================
# 1. Data sources
# ============================================================

# ---- Unified alphanode proxy (CoinGlass klines+derivatives + Glassnode onchain) ----
# 旧系统架构:CoinGlass 和 Glassnode 共享中转站 https://api.alphanode.work
# 鉴权:HTTP header "x-key"(小写,连字符)
# 两个 API_KEY 变量通常填**同一个** alphanode 中转站 key
# (变量保留独立是为了将来可能切换单独的供应商)
#
# Binance 已从架构中移除:api.binance.com 和 fapi.binance.com 对美国 IP 返回 451,
# data.binance.vision 是静态仓库非 REST。见 docs/PROJECT_LOG.md 2026-04-23。

# ---- CoinGlass (BTC klines + all derivatives) ----
# Default: https://api.alphanode.work
COINGLASS_BASE_URL=
COINGLASS_API_KEY=your_alphanode_key_here

# ---- Glassnode (on-chain) ----
# Default: https://api.alphanode.work (same proxy as CoinGlass)
# Key is typically the same value as COINGLASS_API_KEY above.
GLASSNODE_BASE_URL=
GLASSNODE_API_KEY=your_alphanode_key_here

# ---- FRED (optional, backup macro source) ----
# Default: https://api.stlouisfed.org/fred
# Register free: https://fred.stlouisfed.org/docs/api/api_key.html
# Leave UNSET to skip FRED entirely (Yahoo is the primary macro source).
FRED_API_KEY=your_fred_key_here

# ---- FRED (backup macro) ----
# Default base_url: https://api.stlouisfed.org/fred/
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_BASE_URL=
FRED_API_KEY=your_fred_key_here

# ---- Yahoo Finance / event calendar ----
# No key needed; leave unset.
YAHOO_FINANCE_BASE_URL=
EVENT_CAL_BASE_URL=
EVENT_CAL_API_KEY=


# ============================================================
# 2. AI (OpenAI-compatible proxy; calls Claude Sonnet 4.5 via novaiapi)
# ============================================================
# Default base_url: https://us.novaiapi.com/v1
# Default model:    claude-sonnet-4-5-20250929
OPENAI_API_BASE=https://us.novaiapi.com/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=claude-sonnet-4-5-20250929

# Optional: different model for L5 macro summary (defaults to OPENAI_MODEL)
OPENAI_L5_MODEL=


# ============================================================
# 3. Application
# ============================================================

# Log level: DEBUG | INFO | WARNING | ERROR (overrides base.yaml → logging.level)
LOG_LEVEL=INFO

# SQLite path (overrides base.yaml → paths.db_path). Relative to project root.
DATABASE_URL=sqlite:///data/btc_strategy.db

# FastAPI server (v0.4+)
API_HOST=127.0.0.1
API_PORT=8000
