# ============================================================
# BTC Swing System — Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real keys.
#
# Reference:
#   - config/data_sources.yaml  (data sources, takes `..._BASE_URL` / `..._API_KEY`)
#   - config/ai.yaml            (AI endpoint + model)
# All variables below are OPTIONAL if the corresponding config has a
# usable `*_default`; they only need to be set to OVERRIDE the default.
# ============================================================


# ============================================================
# 1. Data sources
# ============================================================

# ---- Binance (spot + U-margin futures, direct to official) ----
# Defaults in data_sources.yaml:
#   base_url_default         = https://api.binance.com
#   futures_base_url_default = https://fapi.binance.com
# Public endpoints do NOT need a key. Leave these UNSET unless you run
# behind a custom proxy (then set the URL; key still usually not needed).
BINANCE_BASE_URL=
BINANCE_FUTURES_BASE_URL=

# ---- Glassnode (on-chain) via alphanode proxy ----
# Default base_url: https://api.alphanode.work
GLASSNODE_BASE_URL=
GLASSNODE_API_KEY=your_alphanode_key_here

# ---- Coinglass (derivatives aggregator) via alphanode proxy ----
# Default base_url: https://api.alphanode.work (shared with Glassnode).
# Most users set this to the SAME value as GLASSNODE_API_KEY because the
# proxy issues one key for both; keep the variables separate so you can
# split later without touching code.
COINGLASS_BASE_URL=
COINGLASS_API_KEY=your_alphanode_key_here

# ---- FRED (backup macro) ----
# Default base_url: https://api.stlouisfed.org/fred/
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_BASE_URL=
FRED_API_KEY=your_fred_key_here

# ---- Yahoo Finance / event calendar ----
# No key needed; leave unset.
YAHOO_FINANCE_BASE_URL=
EVENT_CAL_BASE_URL=
EVENT_CAL_API_KEY=


# ============================================================
# 2. AI (OpenAI-compatible proxy; calls Claude Sonnet 4.5 via novaiapi)
# ============================================================
# Default base_url: https://us.novaiapi.com/v1
# Default model:    claude-sonnet-4-5-20250929
OPENAI_API_BASE=https://us.novaiapi.com/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=claude-sonnet-4-5-20250929

# Optional: different model for L5 macro summary (defaults to OPENAI_MODEL)
OPENAI_L5_MODEL=


# ============================================================
# 3. Application
# ============================================================

# Log level: DEBUG | INFO | WARNING | ERROR (overrides base.yaml → logging.level)
LOG_LEVEL=INFO

# SQLite path (overrides base.yaml → paths.db_path). Relative to project root.
DATABASE_URL=sqlite:///data/btc_strategy.db

# FastAPI server (v0.4+)
API_HOST=127.0.0.1
API_PORT=8000
